---
import Dock from "../components/dock";
import FloatingSocials from "../components/FloatingSocials";
import Footer from "../components/footer.astro";
import SquareLines from "../components/square-lines.astro";
import LoadingScreen from "../components/LoadingScreen";
import "../assets/css/main.css";

const {
  title,
  description,
  socialImage = "/social-card.png",
} = Astro.props;

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImageUrl = new URL(socialImage, siteUrl).toString();
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico?v=2" />
    <link rel="shortcut icon" href="/favicon.ico?v=2" />
    <meta name="theme-color" content="#fafafa" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Rishwanth Perumandla" />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content="Rishwanth Perumandla, Backend and AI Engineer" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@rishwanth1729" />
    <meta name="twitter:creator" content="@rishwanth1729" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content="Rishwanth Perumandla, Backend and AI Engineer" />
    
    <!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-K4QSSK6SNE"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-K4QSSK6SNE');
</script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=JetBrains+Mono:wght@400;500&family=Kenia&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">

    {/* Inline script to prevent flash of content */}
    <script is:inline>
      (function() {
        const hasVisited = sessionStorage.getItem('hasVisited');
        if (!hasVisited) {
          // Add class to hide content until loading screen finishes
          document.documentElement.style.overflow = 'hidden';
        }
      })();
    </script>

    <style is:global>
      :root {
        --font-sans: 'DM Sans', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
      }
      
      body {
        font-family: var(--font-sans);
        background-color: #fafafa;
        color: #171717;
        -webkit-font-smoothing: antialiased;
      }

      .font-mono { font-family: var(--font-mono); } 
      @keyframes gradient {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.animate-gradient {
  background-size: 200% 200%;
  animation: gradient 3s ease infinite;
}

.will-change-transform {
  will-change: transform;
  transform: translateZ(0);
  backface-visibility: hidden;
}
    </style>
  </head>
  
  <body class="relative min-h-screen flex flex-col">
    <LoadingScreen client:only="react" />
    <SquareLines />
    <FloatingSocials client:load />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />

    <div class="fixed bottom-6 left-0 right-0 z-50 flex justify-center pointer-events-none">
        <div class="pointer-events-auto">
            <Dock client:idle />
        </div>
    </div>
<div class="fixed top-0 left-0 h-[2px] bg-neutral-900 z-[60] progress-bar" style="width: 0%"></div>

<script>
  const progressBar = document.querySelector('.progress-bar') as HTMLElement;
  window.addEventListener('scroll', () => {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    progressBar.style.width = scrolled + "%";
  });

  // Re-enable scrolling after loading screen finishes (1700ms)
  setTimeout(() => {
    document.documentElement.style.overflow = '';
  }, 1700);
</script>
  </body>
</html>
